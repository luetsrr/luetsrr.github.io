---
import Layout from "../layouts/Layout_.astro";

type Frontmatter = {
  draft: boolean;
  pubDate: string;
  title: string;
  date: string;
  update?: string;
  description: string;
  tags: string[];
  new?: boolean;
};

const allPosts = await Astro.glob("./posts/*.md");

const nonDraftPosts = allPosts.filter(
  (post: any) => !post.frontmatter.draft
);

const sortedPosts = nonDraftPosts.sort((a: any, b: any) => {
  const aDate = new Date(a.frontmatter.pubDate);
  const bDate = new Date(b.frontmatter.pubDate);
  return bDate.getTime() - aDate.getTime();
});

const allTags = Array.from(
  new Set(
    sortedPosts.flatMap(
      (post: any) => post.frontmatter.tags || []
    )
  )
);
---

<Layout title="お知らせ - 第8回うぃーすた全国交流会">
  <div class="overflow-hidden relative z-[-1] mt-[80px] lg:mt-[78px] bg-[#fffdfd] border-b-[4px] border-red-100 w-full md:h-72 max-md:h-64 flex flex-col justify-center pl-8 zen-kaku-gothic-new">
    <span class="overflow-hidden ml-10 pt-3 max-md:ml-1 text-[50px] font-bold outline-text tracking-widest shiny-slide z-0">
      NEWS
    </span>

    <span class="bg-[#fffdfd] mt-3 ml-10 pb-3 h-30 max-md:ml-1 text-[20px] z-10">
      お知らせ
    </span>
  </div>

  <div
    class="bg-white/30 text-color zen-kaku-gothic-new text-sm lg:text-base min-h-[calc(100vh-370px)]"
    style="line-height: 2.05;"
  >
    <div class="fade-in margin-contents pt-8 md:px-12 max-md:px-6">

      <div class="h-[15px] md:h-[40px]"></div>

      <!-- タグボタン -->
      <div class="flex flex-wrap gap-2 mb-6 mx-1">
        <button
          class="tag-btn px-3 py-1 rounded-full border border-red-200 text-sm bg-red-200 text-black"
          data-tag="ALL"
        >
          すべて
        </button>

        {allTags.map((tag) => (
          <button
            class="tag-btn px-3 py-1 rounded-full border text-sm bg-white text-black border-red-200"
            data-tag={tag}
          >
            {tag}
          </button>
        ))}
      </div>

      <div class="h-[5px] md:h-[20px]"></div>

      <!-- 投稿一覧 -->
      <ul
        id="post-list"
        style="margin-left: 0.25rem; margin-right: 0.25rem;"
      >
        {sortedPosts.map((post: any) => (
          <li
            class="post-item"
            data-tags={(post.frontmatter.tags || []).join(",")}
          >
            <div class="flex items-center gap-2 flex-wrap">

              <!-- 日付 -->
              {post.frontmatter.update ? (
                <div class="update-content flex items-center gap-1">
                  <a class="text-lg">
                    {post.frontmatter.date}
                  </a>

                  <a class="text-lg text-red-500">
                    {post.frontmatter.update}
                  </a>
                </div>
              ) : (
                <div class="no-update-content mb-[3px] mr-1">
                  <a class="text-base max-lg:text-[14px]">
                    {post.frontmatter.date}
                  </a>
                </div>
              )}

              <!-- タグ -->
              {post.frontmatter.tags && (
                <div class="flex gap-1 flex-wrap mr-1">
                  {post.frontmatter.tags.map((tag: string) => (
                    <span
                      class="text-xs px-2 py-[2px] rounded-full text-black border border-red-200 bg-white"
                    >
                      {tag}
                    </span>
                  ))}
                </div>
              )}

              <!-- タイトル -->
              <a
                class="lg:mb-[3px] text-base max-xl:text-sm font-medium hover-color3 flex items-center gap-2"
                href={post.url}
              >
                {post.frontmatter.new && (
                  <span class="text-red-500 font-bold text-base max-xl:text-sm">
                    NEW!
                  </span>
                )}

                {post.frontmatter.title}
              </a>
            </div>

            <!-- 説明 -->
            <a class="text-base block mt-1">
              {post.frontmatter.description}
            </a>

            <div style="height:20px;" />
          </li>
        ))}
      </ul>

      <!-- ページネーション -->
      <div
        id="pagination-area"
        class="flex justify-center items-center gap-4 mt-10"
      >
        <button
          id="prev-btn"
          class="px-4 py-2 rounded"
        >
          ←
        </button>

        <span id="page-info"></span>

        <button
          id="next-btn"
          class="px-4 py-2 rounded"
        >
          →
        </button>
      </div>

      <div style="height: 200px"></div>
    </div>
  </div>

  <script>
    const buttons =
      document.querySelectorAll(".tag-btn");

    const posts = Array.from(
      document.querySelectorAll(".post-item")
    );

    const prevBtn =
      document.getElementById("prev-btn");

    const nextBtn =
      document.getElementById("next-btn");

    const pageInfo =
      document.getElementById("page-info");

    const POSTS_PER_PAGE = 10;

    let currentPage = 1;
    let currentTag = "ALL";

    function getFilteredPosts() {
      return posts.filter((post) => {
        const tags = (post.dataset.tags || "")
          .split(",")
          .map((t) => t.trim());

        return (
          currentTag === "ALL" ||
          tags.includes(currentTag)
        );
      });
    }

    function renderPosts() {
      const filteredPosts =
        getFilteredPosts();

      const totalPages = Math.max(
        1,
        Math.ceil(
          filteredPosts.length /
          POSTS_PER_PAGE
        )
      );

      if (currentPage > totalPages) {
        currentPage = totalPages;
      }

      posts.forEach((post) => {
        post.style.display = "none";
      });

      const start =
        (currentPage - 1) *
        POSTS_PER_PAGE;

      const end =
        start + POSTS_PER_PAGE;

      filteredPosts
        .slice(start, end)
        .forEach((post) => {
          post.style.display = "block";
        });

      pageInfo.textContent =
        currentPage +
        " / " +
        totalPages;

      prevBtn.disabled =
        currentPage === 1;

      nextBtn.disabled =
        currentPage === totalPages;
    }

    buttons.forEach((button) => {
      button.addEventListener(
        "click",
        () => {
          currentTag =
            button.dataset.tag || "ALL";

          currentPage = 1;

          buttons.forEach((btn) => {
            btn.classList.remove(
              "bg-red-200"
            );

            btn.classList.add(
              "bg-white"
            );
          });

          button.classList.remove(
            "bg-white"
          );

          button.classList.add(
            "bg-red-200"
          );

          renderPosts();
        }
      );
    });

    prevBtn?.addEventListener(
      "click",
      () => {
        if (currentPage > 1) {
          currentPage--;
          renderPosts();
        }
      }
    );

    nextBtn?.addEventListener(
      "click",
      () => {
        const filteredPosts =
          getFilteredPosts();

        const totalPages =
          Math.ceil(
            filteredPosts.length /
            POSTS_PER_PAGE
          );

        if (
          currentPage < totalPages
        ) {
          currentPage++;
          renderPosts();
        }
      }
    );

    renderPosts();
  </script>
</Layout>