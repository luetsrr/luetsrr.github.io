  <div class="hide-on-x">
    <div class="ml-1">
      <p class="mb-2">イベントをタップすることで詳細を確認できます。</p>
      
      <p class="flex flex-wrap items-center gap-y-1">
        <span class="inline-block w-4 h-4 bg-yellow-300 mr-1 rounded-sm"></span>：中高生・学生・社会人
        
        <span class="inline-block w-4 h-4 bg-green-300 ml-4 mr-1 rounded-sm"></span>：学生・社会人
        
        <span class="w-full block md:hidden h-0"></span>
        
        <span class="inline-block w-4 h-4 bg-blue-300 ml-0 md:ml-4 mr-1 rounded-sm"></span>：中高生
        
        <span class="inline-block w-4 h-4 bg-purple-300 ml-4 mr-1 rounded-sm"></span>：中高生保護者の方
      </p>
    </div>
    <div style="height: 10px;"></div>
    <div class="flex justify-center mt-8">
      <label class="toggle-button-4 relative flex items-center w-[262px] h-[52px] rounded-[25px] border cursor-pointer bg-white">
        <input type="checkbox" id="dateToggle" class="peer absolute opacity-0 w-0 h-0">
    
        <span class="slider absolute top-1 left-1 w-32 h-10 bg-blue-500 rounded-full transition-all duration-700 ease-[cubic-bezier(0.4,0,0.2,1)] z-0 
          peer-checked:bg-[#e26161] 
          peer-checked:translate-x-[0px]">
        </span>
    
        <span class="text-white date date-left absolute top-1/2 left-1 transform -translate-y-1/2 w-32 h-10 flex items-center justify-center font-semibold z-10 pointer-events-none transition-all duration-700 ease-in-out
          peer-checked:opacity-0 
          peer-checked:translate-x-[0px]">
          7月18日(土)
        </span>
    
        <span class="text-white date date-right absolute top-1/2 left-1 transform -translate-y-1/2 w-32 h-10 flex items-center justify-center font-semibold z-10 pointer-events-none transition-all duration-700 ease-in-out opacity-0
          peer-checked:opacity-100 
          peer-checked:translate-x-[0px]">
          7月19日(日)
        </span>
      </label>
    </div>

      <div style="height: 24px;"></div>
      <div class="flex justify-center">
      <div id="tableContainer" class="mx-auto overflow-auto max-h-[640px] max-w-[64rem] border rounded-md shadow-md bg-gray-50 relative">
        <div class="min-w-[810px] relative z-0">

          <table id="timetable" class="border-collapse w-full text-sm relative table-fixed">
            <thead class="table_color sticky top-0 z-[50]">
              <tr>
                <th class="sticky left-0 table_color z-[60] border-b px-4 py-2 text-left text-center w-14"></th>
                {venues.map((venue, i) => (
                  <th class="h-[60px] px-4 py-2 text-center text-white font-medium relative border-b zen-kaku-gothic-new"
                      style={`width: ${venueWidths[i]}px;`}>
                    {venue}
                  </th>
                ))}
              </tr>
            </thead>
            <tbody>
              {times.map((time, index) => (
                <tr data-time={time} class="h-[60px]">
                  <td class="sticky left-0 z-[10] bg-white text-center font-medium zen-kaku-gothic-new p-0 align-top">
                    {/* 箱（td）は動かさず、中身のdivだけを動かします。
                       index === 0 (7:00) の時はずらさず、それ以外は translateY(-50%) で線の上に配置します。
                    */}
                    <div 
                      style={{
                        transform: index === 0 ? "translateY(0)" : "translateY(-50%)",
                        backgroundColor: "white", // 文字の裏を通る線を隠す
                        display: "inline-block",  // 文字の幅に合わせて背景色をつける
                        padding: "0 4px",         // 文字周りの余白（線との距離）

                        position: "relative",
                        zIndex: 20
                      }}
                    >
                      {time}
                    </div>
                  </td>
                  {venues.map((_, i) => (
                    <td class="border-t relative px-4 py-2" style={`width: ${venueWidths[i]}px;`}></td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>

          <!-- イベントブロックレイヤー -->
          <div id="eventsLayer" class="absolute top-0 left-0 w-full h-full zen-kaku-gothic-new"></div>

          <!-- 現在時刻バー -->
          <div id="currentTimeBar"
     class="absolute h-[2px] bg-red-500 z-[0] max-md:w-[100%] md:w-[100%]"
     style="left: 0; top: 0;"></div>
          <div id="currentTimeLabel" class="absolute left-[44%] -translate-y-1/2 bg-red-500 text-xs text-white px-2 py-[2px] rounded-full shadow z-[20] zen-kaku-gothic-new" style="top:0;">現在 --</div>
        </div>
      </div>
      </div>
      <div style="height: 30px"></div>
      <div class="ml-1">
        <p>※プログラムや時間は変更する可能性があります。<br>
          ※表示の都合上、イベントのタイトルなどが見えづらい場合があります。<br>
          ※崩れて見える場合はSafariやChromeなどのブラウザをお使いください。
        </p>
      </div>
      <div style="height: 120px"></div>
    

      
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    
    // ページ内のすべての「拡大ボタン」を探す
    const openButtons = document.querySelectorAll('.zoom-button');

    openButtons.forEach(function(btn) {
      
      // ボタンの近くにある「モーダル」を探す
      // HTML要素(Element)として扱うために型アサーションを行うか、nullチェックが必要
      const container = btn.closest('.image-container');

      // ▼▼▼【修正ポイント】この1行を追加してください ▼▼▼
      if (!container) return; 
      // ▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲

      const modal = container.nextElementSibling; // すぐ下の要素（モーダル）を取得

      // モーダルが見つからなければスキップ
      if (!modal) return;

      // モーダルの中にある「閉じるボタン」を探す
      const closeBtn = modal.querySelector('.close-modal-btn');

      // 親ボックスの影響を受けないよう、モーダルをbody直下へ移動
      document.body.appendChild(modal);

      // 【開く機能】
      btn.addEventListener('click', function() {
        modal.classList.add('is-open');
        document.body.style.overflow = 'hidden'; // 背景スクロール禁止
      });

      // 【閉じる機能】関数化
      const closeModal = function() {
        modal.classList.remove('is-open');
        document.body.style.overflow = '';
      };

      // ×ボタンで閉じる
      if (closeBtn) {
        closeBtn.addEventListener('click', closeModal);
      }

      // 背景クリックで閉じる
      modal.addEventListener('click', function(e) {
        if (e.target === modal) {
          closeModal();
        }
      });

    });
  });
</script>

  <script>
    const container = document.getElementById("tableContainer")!;
    const tbody = document.querySelector("#timetable tbody")!;
    const eventsLayer = document.getElementById("eventsLayer")!;

    // 🔸 日付ごとのイベント一覧
    const eventsData = {
      "7/18": [
        { start: "12:00", end: "13:00", venue: "研修室AB", name: "受付", description: "", color: "", target: "中高生・学生・社会人" },
        { start: "12:30", end: "13:00", venue: "和室小", name: "受付", description: "", color: "bg-purple-300", target: "中高生保護者の方" },
        { start: "13:00", end: "16:35", venue: "和室小", name: "保護者座談会", description: "中高生交流会の開催に併せ、別室にて中高生の保護者の方を対象とした座談会を開催します。<br>お子さんが交流会を楽しんでいる間、保護者の方同士で気兼ねなくお話ししましょう。", color: "bg-purple-300", target: "中高生保護者の方" },
        { start: "13:00", end: "13:15", venue: "研修室AB", name: "開会式", description: "実行委員長の挨拶や、うぃーすたのご紹介などを行います。<br>楽しい2日間の始まりです！", color: "", target: "中高生・学生・社会人" },
        { start: "13:25", end: "14:40", venue: "研修室AB", name: "グループトーク", description: "グループに分かれてグループトークを行います。<br>吃音のことだけでなく、趣味や仕事の話などさまざま。", color: "bg-green-300", target: "学生・社会人" },
        { start: "13:25", end: "14:40", venue: "研修室C", name: "アイスブレイク・グループトーク", description: "少人数のグループに分かれて、吃音のことや趣味など楽しくお話ししましょう！<br>上手く話す必要はありません。もちろん時間が掛かっても大丈夫。", color: "bg-blue-300", target: "中高生" },
        { start: "14:50", end: "15:55", venue: "研修室AB", name: "ビンゴ大会", description: "豪華景品が当たるかも！？", color: "", target: "中高生・学生・社会人" },
        { start: "16:40", end: "17:00", venue: "大阪国際ユースホステル", name: "チェックイン", description: "", color: "", target: "中高生・学生・社会人" },
        { start: "17:00", end: "19:30", venue: "バーベキューガーデン羽衣", name: "BBQ", description: "みんなでBBQを楽しみましょう！", color: "", target: "中高生・学生・社会人" },
        { start: "19:30", end: "20:00", venue: "バーベキューガーデン羽衣", name: "花火@浜寺公園", description: "夏の風物詩、花火で、1日の最後を締めくくりましょう！<br>バーベキューガーデン羽衣横の浜寺公園にて行います。", color: "bg-blue-300", target: "中高生" },
        { start: "20:00", end: "23:00", venue: "大阪国際ユースホステル", name: "フリータイム", description: "入浴やロビーでの歓談など、思い思いにお過ごしください。", color: "", target: "中高生・学生・社会人" },
      ],
      "7/19": [
        { start: "07:45", end: "08:25", venue: "大阪国際ユースホステル", name: "朝食", description: "", color: "", target: "中高生・学生・社会人" },
        { start: "08:30", end: "09:00", venue: "大阪国際ユースホステル", name: "チェックアウト", description: "", color: "", target: "中高生・学生・社会人" },
        { start: "09:05", end: "10:40", venue: "研修室C", name: "キーホルダー作り", description: "プラスチック板に自由に絵を描いて、オリジナルのキーホルダーやアクセサリーなどを作ります！<br>※希望者はレジン（ハンドメイド工作に使う樹脂）を使用できます。", color: "bg-blue-300", target: "中高生" },
        { start: "09:05", end: "9:35", venue: "研修室AB", name: "グループトーク", description: "グループに分かれてグループトークを行います。<br>吃音のことだけでなく、趣味や仕事の話などさまざま。", color: "bg-green-300", target: "学生・社会人" },
        { start: "09:35", end: "10:40", venue: "研修室AB", name: "マイメッセージ", description: "吃音にまつわる体験、思い、みんなに伝えたいことなどを自由に発表していただくプログラムです。<br>※希望者のみ", color: "bg-green-300", target: "学生・社会人" },
        { start: "10:50", end: "12:00", venue: "研修室AB", name: "クイズ大会", description: "チームで対抗してポイントを競い合います！", color: "", target: "中高生・学生・社会人" },
        { start: "12:00", end: "12:20", venue: "研修室AB", name: "閉会式", description: "楽しかった2日間もこれでおしまい。<br>最後までみんなと同じときを過ごしましょう。", color: "", target: "中高生・学生・社会人" },
      ]
    };

    let currentDate = "7/18";
    let eventsList: any[] = [];

    // イベントブロックを生成
    function renderEvents() {
      eventsLayer.innerHTML = "";
      eventsList = eventsData[currentDate].map(ev => {
        const div = document.createElement("div");
        
        // データに color があればそれを使い、なければデフォルトで bg-yellow-300 を使う
        const bgColor = ev.color ? ev.color : "bg-yellow-300";
        
        // テンプレートリテラルを使ってクラス名を動的に埋め込みます
        div.className = `event-block rounded absolute ${bgColor} border border-gray-300 text-black px-2 py-2 z-[0] flex flex-col cursor-pointer hover:opacity-90 transition-opacity hover:z-[30] overflow-hidden`;

        const title = document.createElement("div");
        title.className = "font-medium text-sm";
        title.textContent = ev.name;
        const time = document.createElement("div");
        time.className = "text-xs text-black mt-1";
        time.textContent = `${ev.start}〜${ev.end}`;
        div.appendChild(title);
        div.appendChild(time);
        eventsLayer.appendChild(div);
        ev.div = div;
        return ev;
      });
      positionEvents();
      setupModal();
    }

    function positionEvents() {
      const containerRect = container.getBoundingClientRect();
      const rows = [...tbody.querySelectorAll("tr")];

      eventsList.forEach(ev => {
        const venueIndex = ["研修室AB","研修室C","和室小","大阪国際ユースホステル","バーベキューガーデン羽衣"].indexOf(ev.venue);
        if (venueIndex === -1) return;

        const td = tbody.querySelectorAll("tr:first-child td")[venueIndex + 1]!;
        const tdRect = td.getBoundingClientRect();

        const [sh, sm] = ev.start.split(":").map(Number);
        const [eh, em] = ev.end.split(":").map(Number);
        const startMinutes = sh*60 + sm;
        const endMinutes = eh*60 + em;

        let baseRow = rows[0]!;
        for (let row of rows) {
          const rowMinutes = row.dataset.time!.split(":").map(Number).reduce((h,m)=>h*60+m);
          if (rowMinutes <= startMinutes) baseRow = row;
          else break;
        }
        const nextRow = baseRow.nextElementSibling || baseRow;
        const baseRect = baseRow.getBoundingClientRect();
        const nextRect = nextRow.getBoundingClientRect();
        const rowStartMinutes = baseRow.dataset.time!.split(":").map(Number).reduce((h,m)=>h*60+m);
        const ratio = (startMinutes - rowStartMinutes)/60;
        const topPx = baseRect.top - containerRect.top + ratio*(nextRect.top - baseRect.top) + container.scrollTop;
        const heightPx = (endMinutes - startMinutes)/60 * baseRect.height;
        const widthPx = tdRect.width;
        ev.div.style.top = `${topPx}px`;
        ev.div.style.left = `${tdRect.left - containerRect.left + container.scrollLeft - 1.5}px`;
        ev.div.style.width = `${widthPx}px`;
        ev.div.style.height = `${heightPx}px`;
      });
    }

    // モーダル設定関数
    function setupModal() {
      const modal = document.getElementById("eventModal")!;
      const modalTitle = document.getElementById("modalTitle")!;
      const modalDescription = document.getElementById("modalDescription")!;
      const modalTime = document.getElementById("modalTime")!;
      
      const modalVenue = document.getElementById("modalVenue")!;
      const modalTarget = document.getElementById("modalTarget")!;

      const modalClose = document.getElementById("modalClose")!;

      eventsList.forEach(ev => {
        ev.div.addEventListener("click", () => {
          modalTitle.textContent = ev.name;
          modalDescription.innerHTML = ev.description || "詳細情報なし";
          modalVenue.textContent = `場所：${ev.venue}`;
          modalTarget.textContent = ev.target ? `対象：${ev.target}` : "";

          modalTime.textContent = `時間：${ev.start}〜${ev.end}`;
          modal.classList.remove("hidden");
          modal.classList.add("flex");
        });
      });

      modalClose.addEventListener("click", () => modal.classList.add("hidden"));
      modal.addEventListener("click", e => {
        if (e.target === modal) modal.classList.add("hidden");
      });
    }

    // 現在時刻バー更新
    const bar = document.getElementById("currentTimeBar")!;
    const label = document.getElementById("currentTimeLabel")!;
    function updateTimeBar() {
      const now = new Date();
      const currentMinutes = now.getHours()*60 + now.getMinutes();
      const rows = [...tbody.querySelectorAll("tr")] as HTMLTableRowElement[];
      let visible = false;
      for (let i=0; i<rows.length-1; i++) {
        const [sh,sm] = rows[i]!.dataset.time!.split(":").map(Number);
        const [eh,em] = rows[i+1]!.dataset.time!.split(":").map(Number);
        const startM = sh!*60 + sm!;
        const endM = eh!*60 + em!;
        if (currentMinutes >= startM && currentMinutes < endM) {
          const startRect = rows[i]!.getBoundingClientRect();
          const endRect = rows[i+1]!.getBoundingClientRect();
          const parentRect = container.getBoundingClientRect();
          const ratio = (currentMinutes - startM)/(endM - startM);
          const offset = startRect.top + ratio*(endRect.top - startRect.top);
          const topPos = offset - parentRect.top + container.scrollTop;
          bar.style.top = `${topPos}px`;
          label.style.top = `${topPos}px`;
          label.textContent = `現在時刻 ${String(now.getHours()).padStart(2,"0")}:${String(now.getMinutes()).padStart(2,"0")}`;
          visible = true;
          break;
        }
      }
      if (!visible) { bar.style.top = "-9999px"; label.style.top = "-9999px"; }
    }

    

    // 初期描画
    renderEvents();
    updateTimeBar();
    setInterval(updateTimeBar, 30000);
    container.addEventListener("scroll", positionEvents);
    window.addEventListener("resize", positionEvents);

    // 🔸 日付切り替えボタン処理
    document.querySelectorAll(".date-btn").forEach(btn => {
  const button = btn as HTMLButtonElement;
  button.addEventListener("click", () => {
    document.querySelectorAll(".date-btn").forEach(b =>
      (b as HTMLButtonElement).classList.remove("bg-blue-300", "text-blue-800")
    );
    button.classList.add("bg-blue-300", "text-blue-800");
    currentDate = button.dataset.date!;
    renderEvents();
  });
});


    const toggle = document.getElementById("dateToggle")! as HTMLInputElement;;

toggle.addEventListener("change", () => {
  currentDate = toggle.checked ? "7/19" : "7/18";
  renderEvents();
});
  </script>
</Layout>

<!-- モーダル -->
<div id="eventModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-[20000] zen-kaku-gothic-new">
  <div class="bg-white p-6 rounded-3xl shadow-lg max-w-sm w-2/3 relative">
    <button id="modalClose" class="absolute top-3 right-6 text-gray-500 hover:text-black text-[24px]">&times;</button>
    <h3 id="modalTitle" class="font-bold text-lg mb-2 pr-8"></h3>
    
    <p id="modalTime" class="text-sm text-black mt-2"></p>
    <p id="modalVenue" class="text-sm text-black mt-1"></p>
    <p id="modalTarget" class="text-sm text-black mt-1 font-medium"></p>
    <div style="height: 10px"></div>
    <p id="modalDescription" class="text-sm text-black whitespace-pre-wrap"></p>
    
  </div>
</div>
