const times = ["","7:00","8:00","9:00","10:00","11:00","12:00","13:00","14:00","15:00","16:00","17:00","18:00","19:00","20:00","21:00","22:00","23:00"];
const venues = ["研修室AB", "研修室C", "和室小", "大阪国際ユースホステル", "バーベキューガーデン羽衣"];
const venueWidths = [150, 150, 150, 150, 150];
