<style is:global>
/* --- 既存のコードの下などに追加 --- */

.responsive-logo {
  /* スマホでは画面の80%くらいの幅を上限にする */
  width: 90%;
  /* PCなど大きな画面では最大300pxまでしか大きくならないようにする */
  max-width: 300px;
  height: auto;
  display: block;
}

@media (max-width: 768px) {
  .responsive-logo {
    /* スマホで中央寄せにしたい場合は、親要素のjustify-contentをcenterに変えるか
       以下のようにmarginを調整します */
    
    width: 60%; /* スマホでの好みのサイズ感に合わせて調整してください */
  }
}
</style>

<style is:global>
/* --- ベース設定 --- */

.scroll-container {
  /* 最初の「空白状態」を作るため */
  position: relative;
}

.sticky-wrapper {
  position: sticky;
  top: 0px;
  /* スマホのブラウザバー（アドレスバーなど）を考慮した高さ設定 */
  height: 100dvh; 
  width: 100%;
  overflow: hidden;
  background-color: #fff3f375;
}

.scroll-indicator {
  position: fixed; 
  bottom: 30px; /* スマホでも見やすい位置に少し上げました */
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  pointer-events: none;
  z-index: 1; 
  will-change: opacity;
}

@keyframes scroll-line {
  0% { transform: translateY(-100%); }
  100% { transform: translateY(100%); }
}

.triangle-arrow {
  width: 12px;
  height: 12px;
  border-bottom: 2px solid #000000; 
  border-right: 2px solid #000000;
  transform: rotate(45deg);
  will-change: transform;
  animation: triangle-bounce 1.5s infinite; 
}

@keyframes triangle-bounce {
  0%, 100% {
    transform: translateY(0) rotate(45deg);
    opacity: 1; 
  }
  50% {
    transform: translateY(8px) rotate(45deg); 
    opacity: 1; 
  }
}

/* --- 各セクションの設定 --- */
.content-section {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 70px;
  box-sizing: border-box;
  
  max-width: 1100px;
  margin: 0 auto;
  left: 50%;
  transform: translateX(-50%);
  pointer-events: none;
}

.content-section.reverse {
  flex-direction: row-reverse;
}

/* --- テキストと画像のスタイル --- */
.text-box { flex: 1; }
.text-box h2 { font-size: 2.3rem; margin-bottom: 24px; font-weight: normal; }
.text-box p { font-size: 1.3rem; line-height: 2; color: #000000; }
.h-midashi { font-size: 2.3rem; margin-bottom: 24px; font-weight: normal; }
.p-midashi { font-size: 1.3rem; line-height: 2; color: #000000; }

.split-text span {
  will-change: opacity;
}

.image-box {
  opacity: 0;
  will-change: opacity;
}

.image-box img {
  height: auto;
  border-radius: 4px;

}

@media screen and (min-width:768px) and (max-width:1248px) {
  .content-section, .content-section.reverse {
    /* 縦並びに変更 */
    flex-direction: column;
    gap: 36px;
    /* ヘッダーの余白 + 左右の余白 + 下部の余白 */
    padding: 155px 80px 40px;
    max-width: 800px;
  }

  .text-box { max-width: 600px; }

  /* HTMLの記述順に関わらず、必ず「画像が上・テキストが下」になるように強制 */
  .image-box { 
    order: 1; 
    width: 100%; 
  }
  .text-box { 
    order: 2; 
    width: 100%;
    text-align: left; /* スマホでは中央揃えの方が見栄えが良い場合はここを活かす */
  }

  .text-box h2 { 
    font-size: 2.0rem; 
    margin-bottom: 12px; 
  }
  .text-box p { 
    font-size: 1.3rem; /* 1.5remから縮小し、読みやすく */
    line-height: 2.0; 
  }
}

/* --- ★スマホ用レスポンシブ設定 --- */
@media (max-width: 768px) {
  .content-section, .content-section.reverse {
    /* 縦並びに変更 */
    flex-direction: column;
    gap: 24px;
    /* ヘッダーの余白 + 左右の余白 + 下部の余白 */
    padding: 125px 28px 40px; 
    max-width: 480px;
  }

  /* HTMLの記述順に関わらず、必ず「画像が上・テキストが下」になるように強制 */
  .image-box { 
    order: 1; 
    width: 100%; 
  }
  .text-box { 
    order: 2; 
    width: 100%;
    text-align: left; /* スマホでは中央揃えの方が見栄えが良い場合はここを活かす */
  }

  /* 画像が画面を埋め尽くさないよう高さを制限 */
  .image-box img {
    max-height: 35vh; 
    width: auto;
    max-width: 100%;
    margin: 0 auto;
    display: block;
  }

  /* スマホ向けの文字サイズに縮小 */
  .text-box h2 { 
    font-size: 1.5rem; 
    margin-bottom: 12px; 
  }
  .text-box p { 
    font-size: 1rem; /* 1.5remから縮小し、読みやすく */
    line-height: 2.0; 
  }

  /* 最後の余白コンテンツのスマホ対応 */
  .h-midashi { font-size: 1.6rem; margin-bottom: 16px; text-align: left; }
  .p-midashi { font-size: 1rem; text-align: left; }
}
</style>

<script>
import Lenis from 'lenis';

const initAnimation = () => {
  // 1. Lenisの設定
  const lenis = new Lenis({
    duration: 1.5,
    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
  });

  function raf(time) {
    lenis.raf(time);
    requestAnimationFrame(raf);
  }
  requestAnimationFrame(raf);

  // 2. テキストの分割処理（<br>対応）
  const splitTextElements = document.querySelectorAll('.split-text');
  splitTextElements.forEach(el => {
    const nodes = Array.from(el.childNodes);
    el.innerHTML = ''; 
    
    nodes.forEach(node => {
      if (node.nodeType === Node.TEXT_NODE) {
        const text = node.textContent || '';
        text.split('').forEach(char => {
          const span = document.createElement('span');
          span.textContent = char;
          span.style.opacity = '0'; 
          el.appendChild(span);
        });
      } else if (node.nodeName.toLowerCase() === 'br') {
        el.appendChild(document.createElement('br'));
      }
    });
  });

  // 3. スクロール連動処理
  const container = document.getElementById('fade-container');
  const sections = document.querySelectorAll('.content-section');
  const indicator = document.getElementById('scroll-indicator');
  const numSections = sections.length;

  if (!container || numSections === 0) return;

  // ★自動調整: セクション1つにつき「200vh」のスクロール距離を確保する
  // これにより、セクションが何個増えてもアニメーションのゆとりが変わりません
  container.style.height = `${numSections * 200}vh`;

  window.addEventListener('scroll', () => {
    const rect = container.getBoundingClientRect();
    const scrollY = -rect.top;
    const maxScroll = rect.height - window.innerHeight;

    let progress = scrollY / maxScroll;
    progress = Math.max(0, Math.min(1, progress));

    // SCROLL文字のフェードアウト
    if (indicator) {
      let indicatorOpacity = (1 - progress) * 10; 
      indicatorOpacity = Math.max(0, Math.min(1, indicatorOpacity));
      indicator.style.opacity = indicatorOpacity.toString();
    }

    // ★各セクションの表示計算を「何個増えても崩れないローカル計算式」に変更
    sections.forEach((section, index) => {
      // 0〜1の進行度を、各セクションごとの単位に変換
      const localProgress = (progress * numSections) - index;
      
      // 0.5（そのセクションのど真ん中）からの距離を測る（0.0〜0.5）
      const localDistance = Math.abs(localProgress - 0.5);

      // --- アニメーションのタイミング調整 ---
      const holdArea = 0.15; // 完全表示をキープする幅（数値が大きいほど長く留まる）
      const fadeArea = 0.20; // フェードイン/アウトにかける幅
      // ※ 上記を足した 0.35 以外の 0.15 分（0.5 - 0.35）が「完全な空白（余白）」になります

      let visibility = 0;
      if (localDistance <= holdArea) {
        visibility = 1; // 完全表示
      } else if (localDistance >= holdArea + fadeArea) {
        visibility = 0; // 完全非表示（余白期間）
      } else {
        // フェードイン または フェードアウト中
        visibility = 1 - ((localDistance - holdArea) / fadeArea);
      }

      // 画像のフェード適用
      const imageBox = section.querySelector('.image-box');
      if (imageBox) {
        (imageBox as HTMLElement).style.opacity = visibility.toString();
      }

      // 文字のフェード適用
      const textBoxes = section.querySelectorAll('.split-text');
      textBoxes.forEach(box => {
        const spans = box.querySelectorAll('span');
        const total = spans.length;
        if(total === 0) return;

        spans.forEach((span, i) => {
          // 1文字ずつの時間差を作る
          const charStart = (i / total) * 0.8;
          const charEnd = charStart + 0.2; 

          let charOpacity = (visibility - charStart) / (charEnd - charStart);
          charOpacity = Math.max(0, Math.min(1, charOpacity));
          
          span.style.opacity = charOpacity.toString();
        });
      });
    });
  });

  window.dispatchEvent(new Event('scroll'));
};

initAnimation();
</script>