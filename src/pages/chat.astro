---
import "katex/dist/katex.min.css";
import "remixicon/fonts/remixicon.css";
import "../styles/output.css";
---
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>チャット - 第8回うぃーすた全国交流会</title>
</head>
<body>

    <div class="app-container glass-panel">
        <h2 class="section-title title-highlight">リアルタイムチャット</h2>

        <div id="chat-box"></div>

        <div class="preset-area">
            <button class="preset-btn btn-reach" data-msg="リーチ！" data-color="reach">リーチ！</button>
            <button class="preset-btn btn-bingo" data-msg="BINGO!" data-color="bingo">BINGO！</button>
        </div>

        <div class="input-area">
            <input type="text" id="message-input" placeholder="メッセージを入力...">
            <button id="send-btn"><i class="ri-send-plane-fill"></i></button>
        </div>
    </div>

    <script is:inline src="https://www.gstatic.com/firebasejs/10.8.0/firebase-app-compat.js"></script>
    <script is:inline src="https://www.gstatic.com/firebasejs/10.8.0/firebase-database-compat.js"></script>

    <script is:inline>
        // 1. Firebaseの設定
        const firebaseConfig = {
            apiKey: "AIzaSyAx1_nza7sR6c8v3_2c-MBZS5yi4y4rE4c",
            authDomain: "bingo-37920.firebaseapp.com",
            databaseURL: "https://bingo-37920-default-rtdb.firebaseio.com",
            projectId: "bingo-37920",
            storageBucket: "bingo-37920.firebasestorage.app",
            messagingSenderId: "858255325745",
            appId: "1:858255325745:web:fec3635297acfb698fb310",
            measurementId: "G-NY97WJKMR2"
        };

        // Firebaseの初期化
        firebase.initializeApp(firebaseConfig);
        const database = firebase.database();
        const chatRef = database.ref('chat_messages');

        // 要素の取得
        const chatBox = document.getElementById('chat-box');
        const messageInput = document.getElementById('message-input');
        const sendBtn = document.getElementById('send-btn');
        let currentNickname = ""; 

        // sessionStorage を使うことで「タブを閉じたら忘れる」ようにしました
        window.addEventListener('DOMContentLoaded', () => {
            let savedName = sessionStorage.getItem('chat_nickname');
            
            while (!savedName || savedName.trim() === '') {
                const inputName = prompt("チャットで使用するニックネームを必ず入力してください：");
                
                if (inputName && inputName.trim() !== '') {
                    savedName = inputName.trim();
                    sessionStorage.setItem('chat_nickname', savedName);
                } else {
                    alert("ニックネームの入力は必須です！");
                }
            }
            
            currentNickname = savedName; 
        });

        // 2. 通常のメッセージ送信処理
        function sendMessage() {
            const message = messageInput.value.trim();

            if (currentNickname === '' || message === '') return;

            chatRef.push({
                nickname: currentNickname, 
                message: message,
                timestamp: Date.now(),
                isPreset: false
            });

            messageInput.value = ''; 
            
            messageInput.blur(); 
            window.scrollTo(0, 0);
        }

        sendBtn.addEventListener('click', sendMessage);
        messageInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendMessage();
        });

        // 定型文ボタンのクリック処理
        document.querySelectorAll('.preset-btn').forEach(button => {
            button.addEventListener('click', () => {
                if (currentNickname === '') {
                    alert("ニックネームを設定してください。");
                    return;
                }

                const baseMessage = button.getAttribute('data-msg');
                const colorType = button.getAttribute('data-color');
                let finalMessage = baseMessage;

                if (baseMessage === "BINGO!") {
                    finalMessage = `<span class="big-title">BINGO！</span><br><span class="small-sub">${currentNickname}さんがビンゴになりました🎉</span>`;
                } else if (baseMessage === "リーチ！") {
                    finalMessage = `<span class="big-title">リーチ！</span><br><span class="small-sub">${currentNickname}さんがリーチになりました🔥</span>`;
                }

                chatRef.push({
                    nickname: currentNickname,
                    message: finalMessage,
                    timestamp: Date.now(),
                    isPreset: true,
                    colorType: colorType
                });
                
                window.scrollTo(0, 0);
            });
        });

        // 3. メッセージのリアルタイム受信処理
        chatRef.on('child_added', (snapshot) => {
            const data = snapshot.val();
            
            const messageElement = document.createElement('div');
            messageElement.classList.add('message');
            
            let formattedMessage;
            if (data.isPreset === true) {
                formattedMessage = data.message;
            } else {
                formattedMessage = escapeHTML(data.message).replace(/\n/g, '<br>');
            }
            
            if (data.isPreset === true) {
                messageElement.classList.add('preset-message');
                if (data.colorType) {
                    messageElement.classList.add(`color-${data.colorType}`);
                }
                messageElement.innerHTML = `<span class="text-content">${formattedMessage}</span>`;
            } else {
                messageElement.innerHTML = `
                    <div class="msg-author">${escapeHTML(data.nickname)}</div>
                    <div class="msg-bubble"><span class="text-content">${formattedMessage}</span></div>
                `;
            }

            chatBox.appendChild(messageElement);
            chatBox.scrollTop = chatBox.scrollHeight;
        });

        function escapeHTML(str) {
            return str.replace(/[&<>"']/g, match => {
                const escape = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#x27;' };
                return escape[match];
            });
        }
    </script>

</body>
</html>

<style>
    /* ==========================================
       デザイン刷新版レイアウト（モバイル・参加者向け）
    ========================================== */
    :global(html), :global(body) {
        height: 100%;
        height: 100dvh; 
        margin: 0;
        padding: 0;
        overflow: hidden;
        position: fixed; 
        width: 100%;
        font-family: 'Helvetica Neue', Arial, 'Hiragino Kaku Gothic ProN', 'Hiragino Sans', Meiryo, sans-serif;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); /* メイン画面と同じ背景 */
        color: #333;
    }

    .glass-panel {
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-radius: 24px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        border: 1px solid rgba(255, 255, 255, 0.5);
    }

    .app-container {
        position: fixed;
        top: 2dvh;
        left: 50%;
        transform: translateX(-50%);
        width: 92%; /* 画面端に少し余白を作る */
        max-width: 600px;
        height: 96dvh;
        padding: 20px 15px;
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .section-title {
        font-size: 1.35rem;
        font-weight: 900;
        text-align: center;
        margin: 0 0 15px 0;
        letter-spacing: 1px;
    }

    .title-highlight {
        background: linear-gradient(45deg, #ff416c, #ff4b2b);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    #chat-box { 
        border: none;
        flex-grow: 1; 
        overflow-y: auto; 
        -webkit-overflow-scrolling: touch; 
        padding: 15px; 
        margin-bottom: 15px; 
        background: #f8f9fa; 
        border-radius: 16px;
        box-shadow: inset 0 4px 6px rgba(0,0,0,0.03);
    }
    #chat-box::-webkit-scrollbar { width: 6px; }
    #chat-box::-webkit-scrollbar-thumb { background: #ced4da; border-radius: 3px; }

    :global(.message) { 
        margin-bottom: 16px; 
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        width: 100%;
        animation: fadeIn 0.3s ease-out;
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(5px); }
        to { opacity: 1; transform: translateY(0); }
    }

    :global(.msg-author) {
        font-size: 12px;
        color: #7f8c8d;
        font-weight: 700;
        margin-left: 10px;
        margin-bottom: 4px;
    }

    :global(.msg-bubble) {
        padding: 12px 16px; 
        border-radius: 20px; 
        background: #ffffff; 
        box-shadow: 0 2px 8px rgba(0,0,0,0.06); 
        font-size: 15px;
        line-height: 1.5;
        max-width: 85%;
        word-break: break-all;
        border-top-left-radius: 4px; /* 吹き出しっぽさ */
    }

    :global(.message.preset-message) {
        padding: 14px 20px;
        animation: pop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        text-align: left; 
        width: fit-content; 
        max-width: 90%;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        box-sizing: border-box;
    }

    :global(.message.preset-message .text-content) {
        display: block;
        line-height: 1.3;
    }

    :global(.big-title) {
        font-size: 20px; 
        font-weight: 900; 
        letter-spacing: 2px; 
        display: inline-block;
        margin-bottom: 5px;
    }

    :global(.small-sub) {
        font-size: 14px; 
        font-weight: normal; 
        opacity: 0.9; 
        display: inline-block;
    }

    /* BINGO! （ブルーグラデーション） */
    :global(.message.color-bingo) {
        background: linear-gradient(135deg, #00c6ff, #0072ff); 
        border: none; 
        border-radius: 16px;
        color: #fff;
    }
    :global(.message.color-bingo .big-title), :global(.message.color-bingo .small-sub) { 
        color: #ffffff; 
        text-shadow: 1px 1px 2px rgba(0,0,0,0.1);
    }

    /* リーチ！ （オレンジグラデーション） */
    :global(.message.color-reach) {
        background: linear-gradient(135deg, #f6d365, #fda085); 
        border: none;
        border-radius: 16px;
        color: #fff;
    }
    :global(.message.color-reach .big-title), :global(.message.color-reach .small-sub) { 
        color: #ffffff; 
        text-shadow: 1px 1px 2px rgba(0,0,0,0.1);
    }

    @keyframes pop {
        0% { transform: scale(0.8); opacity: 0; }
        100% { transform: scale(1); opacity: 1; }
    }

    .preset-area {
        display: flex;
        gap: 15px;
        margin-bottom: 12px;
        justify-content: center;
    }
    .preset-btn {
        border: none;
        padding: 12px 10px; 
        border-radius: 30px;
        cursor: pointer;
        font-size: 15px;
        font-weight: 900;
        transition: all 0.2s;
        flex: 1;
        max-width: 180px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }
    .preset-btn:hover {
        transform: translateY(-2px);
        filter: brightness(1.1);
    }
    
    .btn-bingo { background: linear-gradient(135deg, #00c6ff, #0072ff); color: white; }
    .btn-reach { background: linear-gradient(135deg, #f6d365, #fda085); color: white; }

    .input-area { 
        display: flex; 
        gap: 10px; 
        background: transparent;
        padding: 5px 0 5px 0; 
    }
    #message-input { 
        flex-grow: 1; 
        padding: 14px 16px; 
        font-size: 15px; 
        border: 1px solid #e0e0e0;
        border-radius: 25px;
        outline: none;
        background: #f8f9fa;
        transition: border 0.3s;
    }
    #message-input:focus {
        border-color: #667eea;
        background: #fff;
    }
    #send-btn {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        box-shadow: 0 4px 10px rgba(102, 126, 234, 0.4);
        transition: transform 0.2s;
        flex-shrink: 0;
    }
    #send-btn:hover {
        transform: scale(1.05);
    }
    #send-btn:active {
        transform: scale(0.95);
    }
</style>