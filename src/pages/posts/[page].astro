---
import Layout from "../../layouts/Layout_.astro";

type Frontmatter = {
  draft: boolean;
  pubDate: string;
  title: string;
  date: string;
  update?: string;
  description: string;
  tags: string[];
  new?: boolean;
};

type Post = {
  frontmatter: Frontmatter;
  url: string;
};

type Pagination = {
  data: Post[];
  url: {
    current?: string;
    next?: string;
    prev?: string;
  };
  currentPage: number;
  lastPage: number;
};

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const allPosts: any = await Astro.glob("./*.md");
  const nonDraftPosts: any = allPosts.filter(
    (post: any) => !post.frontmatter.draft
  );

  const sortedPosts: any = nonDraftPosts.sort((a: any, b: any) => {
    const aDate = new Date(a.frontmatter.pubDate);
    const bDate = new Date(b.frontmatter.pubDate);
    return bDate.getTime() - aDate.getTime();
  });
  return paginate(sortedPosts, { pageSize: 10 });
}

const { page } = Astro.props as { page: Pagination };

const latestPosts = page.data;

const allTags = Array.from(
  new Set(
    latestPosts.flatMap((post) => post.frontmatter.tags || [])
  )
);
---

<Layout title="お知らせ - 第8回うぃーすた全国交流会">
  {/* 上部バナーエリア（高さ 約288px + マージン80px ≈ 370px程度） */}
  <div class="overflow-hidden relative z-[-1] mt-[80px] lg:mt-[78px] bg-[#fffdfd] border-b-[4px] border-red-100 w-full md:h-72 max-md:h-64 flex flex-col justify-center pl-8 zen-kaku-gothic-new">
    <span class="overflow-hidden ml-10 pt-3 max-md:ml-1 text-[50px] font-bold outline-text tracking-widest shiny-slide z-0">
      NEWS
    </span>
    
    <span class="bg-[#fffdfd] mt-3 ml-10 pb-3 h-30 max-md:ml-1 text-[20px] z-10">
      お知らせ
    </span>
  </div>

  {/* 修正ポイント: min-h-[calc(100vh-370px)] を追加 
      画面の高さ(100vh)から上部のバナーとヘッダー分(約370px)を引いた高さを最低確保します。
  */}
  <div class="bg-white/30 text-color zen-kaku-gothic-new text-sm lg:text-base min-h-[calc(100vh-370px)]" style="line-height: 2.05;">
    <div class="fade-in margin-contents pt-8 md:px-12 max-md:px-6">

    <div class="h-[15px] md:h-[40px]"></div>

    <div class="flex flex-wrap gap-2 mb-6 mx-1">
  <button
  class="tag-btn px-3 py-1 rounded-full border border-red-200 text-sm bg-red-200 text-black"
  data-tag="ALL"
>
  すべて
</button>

  {allTags.map((tag) => (
    <button
      class="tag-btn px-3 py-1 rounded-full border text-sm bg-white text-black border-red-200"
      data-tag={tag}
    >
      {tag}
    </button>
  ))}
</div>

<div class="h-[5px] md:h-[10px]"></div>

<script>
  const buttons = document.querySelectorAll<HTMLElement>(".tag-btn");
  const posts = document.querySelectorAll<HTMLElement>(".post-item");
const pagination = document.getElementById("pagination-area");

buttons.forEach((button) => {
  button.addEventListener("click", () => {
    const selectedTag = button.dataset.tag;

    let count = 0;

    posts.forEach((post) => {
      const tags = (post.dataset.tags || "")
        .split(",")
        .map((t) => t.trim());

      const matched =
        selectedTag === "ALL" ||
        (selectedTag && tags.includes(selectedTag));

      if (matched && count < 10) {
        post.style.display = "block";
        count++;
      } else {
        post.style.display = "none";
      }
    });

    // ボタン色変更
    buttons.forEach((btn) => {
      btn.classList.remove("bg-red-200");
      btn.classList.add("bg-white", "text-black");
    });

    button.classList.remove("bg-white");
    button.classList.add("bg-red-200");

    // ページネーション制御
    if (pagination) {
  pagination.hidden = selectedTag !== "ALL";
}
  });
});
</script>

    <ul id="post-list" style="margin-left: 0.25rem; margin-right: 0.25rem;">
  {latestPosts.map((post, index) => (
  <li
    class="post-item"
    style={index >= 10 ? "display:none;" : ""}
    data-tags={(post.frontmatter.tags || []).join(",")}
  >
      <div class="flex items-center gap-2 flex-wrap">

        {/* 日付 */}
        {post.frontmatter.update ? (
          <div class="update-content flex items-center gap-1">
            <a class="text-lg">{post.frontmatter.date}</a>
            <a class="text-lg text-red-500">{post.frontmatter.update}</a>
          </div>
        ) : (
          <div class="no-update-content mb-[3px] mr-1">
            <a class="text-base max-lg:text-[14px]">
              {post.frontmatter.date}
            </a>
          </div>
        )}

        {/* タグ */}
        {post.frontmatter.tags && (
          <div class="flex gap-1 flex-wrap mr-1">
            {post.frontmatter.tags.map((tag: string) => (
              <span
  class="text-xs px-2 py-[2px] rounded-full text-black border border-red-200 bg-white"
>
  {tag}
</span>
            ))}
          </div>
        )}

        {/* タイトル */}
        <a
          class="lg:mb-[3px] text-base max-xl:text-sm font-medium hover-color3 flex items-center gap-2"
          href={post.url}
        >
          {post.frontmatter.new && (
            <span class="text-red-500 font-bold text-base max-xl:text-sm">
              NEW!
            </span>
          )}
          {post.frontmatter.title}
        </a>
      </div>

      {/* 説明 */}
      <a class="text-base block mt-1">
        {post.frontmatter.description}
      </a>

      <div style="height:20px;" />
    </li>
  ))}
</ul>

    {/* ページネーション */}
    <div style="height: 30px;"></div>
    <div id="pagination-area">
    <div
      style="text-align: center; align-items: center; justify-content: center; margin: auto; display: flex;"
    >
      {page.url.prev ? (
        <a
          href={page.url.prev}
          class=""
          style="margin-left: 10px; margin-right: 10px; display: flex; align-items: center; font-size: 15px;"
        >
          <i class="ri-arrow-left-line" style="font-size: 24px;" />
          &nbsp;&nbsp;
        </a>
      ) : (
        <a
          class="null-color"
          style="margin-left: 10px; margin-right: 10px; display: flex; align-items: center; font-size: 15px;"
        >
          <i class="ri-arrow-left-line" style="font-size: 24px;" />
          &nbsp;&nbsp;
        </a>
      )}

      <div style="margin-left: 10px; margin-right: 10px; font-size: 15px;">
        {page.currentPage}&nbsp;/&nbsp;{page.lastPage}
      </div>

      {page.url.next ? (
        <a
          href={page.url.next}
          class=""
          style="margin-left: 10px; margin-right: 10px; display: flex; align-items: center; font-size: 15px;"
        >
          &nbsp;&nbsp;
          <i class="ri-arrow-right-line" style="font-size: 24px;" />
        </a>
      ) : (
        <a
          class="null-color"
          style="margin-left: 10px; margin-right: 10px; display: flex; align-items: center; font-size: 15px;"
        >
          &nbsp;&nbsp;
          <i class="ri-arrow-right-line" style="font-size: 24px;" />
        </a>
      )}
    </div>
    </div>
    <div style="height: 200px"></div>
  </div>
  </div>
</Layout>